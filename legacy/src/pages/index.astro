---
import fs from 'node:fs';
import path from 'node:path';

const SCREENSHOTS_DIR = import.meta.env.PROD
  ? path.resolve('./dist/client/screenshots')
  : path.resolve('./public/screenshots');
const EXTS = new Set(['.png', '.jpg', '.jpeg', '.gif', '.webp', '.avif', '.bmp']);

if (!fs.existsSync(SCREENSHOTS_DIR)) {
  fs.mkdirSync(SCREENSHOTS_DIR, { recursive: true });
}

const items = fs
  .readdirSync(SCREENSHOTS_DIR)
  .filter((name) => !name.startsWith('.') && EXTS.has(path.extname(name).toLowerCase()))
  .map((name) => {
    const stat = fs.statSync(path.join(SCREENSHOTS_DIR, name));
    return {
      name,
      src: `/api/img/${encodeURIComponent(name)}`,
      mtime: stat.mtimeMs,
    };
  })
  .sort((a, b) => b.mtime - a.mtime);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>vibes machine</title>
    <style>
      :root {
        color-scheme: dark;
        --gap: 12px;
        --bg: #0e0e10;
        --fg: #e8e8e8;
        --muted: #888;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      }
      header {
        padding: 18px 20px 4px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }
      header h1 {
        font-size: 14px;
        font-weight: 500;
        margin: 0;
        letter-spacing: 0.02em;
      }
      header .count {
        font-size: 12px;
        color: var(--muted);
      }
      .paste-zone {
        flex: 1;
        min-width: 200px;
        border: 1px dashed #2a2a2e;
        border-radius: 6px;
        padding: 8px 12px;
        font-size: 12px;
        color: var(--muted);
        text-align: center;
        cursor: text;
        transition: border-color 120ms ease, background 120ms ease, color 120ms ease;
        outline: none;
      }
      .paste-zone:hover,
      .paste-zone:focus,
      .paste-zone.focus {
        border-color: #444;
        color: var(--fg);
        background: #15151a;
      }
      .paste-zone.busy { color: #d8a657; border-color: #d8a657; }
      .paste-zone.ok   { color: #8ec07c; border-color: #8ec07c; }
      .paste-zone.err  { color: #fb4934; border-color: #fb4934; }
      .paste-zone kbd {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 11px;
        background: #1c1c1f;
        border: 1px solid #2a2a2e;
        border-radius: 3px;
        padding: 1px 5px;
        color: var(--fg);
      }
      .empty {
        padding: 60px 20px;
        text-align: center;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.6;
      }
      .empty code {
        background: #1c1c1f;
        padding: 2px 6px;
        border-radius: 4px;
        color: var(--fg);
      }
      .grid {
        column-gap: var(--gap);
        column-count: 5;
        padding: var(--gap);
      }
      @media (max-width: 1400px) { .grid { column-count: 4; } }
      @media (max-width: 1024px) { .grid { column-count: 3; } }
      @media (max-width: 700px)  { .grid { column-count: 2; } }
      @media (max-width: 420px)  { .grid { column-count: 1; } }

      .grid figure {
        position: relative;
        margin: 0 0 var(--gap);
        break-inside: avoid;
        border-radius: 8px;
        overflow: hidden;
        background: #1a1a1d;
        cursor: zoom-in;
        transition: transform 120ms ease, box-shadow 120ms ease;
      }
      .grid figure:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 24px rgba(0,0,0,0.4);
      }
      .grid img {
        display: block;
        width: 100%;
        height: auto;
      }
      .grid .del {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: none;
        background: rgba(0, 0, 0, 0.6);
        color: #fff;
        font-size: 14px;
        line-height: 1;
        cursor: pointer;
        opacity: 0;
        transition: opacity 120ms ease, background 120ms ease;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
      }
      .grid figure:hover .del { opacity: 1; }
      .grid .del:hover { background: #fb4934; }

      .modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.92);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 24px;
        cursor: zoom-out;
      }
      .modal.open { display: flex; }
      .modal img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        box-shadow: 0 10px 60px rgba(0,0,0,0.6);
        border-radius: 4px;
      }
      .modal .close {
        position: absolute;
        top: 16px;
        right: 20px;
        background: none;
        border: none;
        color: var(--fg);
        font-size: 28px;
        cursor: pointer;
        line-height: 1;
        opacity: 0.7;
      }
      .modal .close:hover { opacity: 1; }
      .modal .nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: var(--fg);
        font-size: 36px;
        cursor: pointer;
        opacity: 0.5;
        padding: 16px;
        user-select: none;
      }
      .modal .nav:hover { opacity: 1; }
      .modal .prev { left: 8px; }
      .modal .next { right: 8px; }
      .modal .caption {
        position: absolute;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 12px;
        color: var(--muted);
        background: rgba(0,0,0,0.5);
        padding: 4px 10px;
        border-radius: 4px;
        max-width: 80%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>vibes machine</h1>
      <span class="count" id="count">{items.length} {items.length === 1 ? 'image' : 'images'}</span>
      <div class="paste-zone" id="paste-zone" tabindex="0" contenteditable="true" spellcheck="false" aria-label="Paste image from clipboard">
        paste image here <kbd>⌘V</kbd>
      </div>
    </header>

    <div class="empty" id="empty" style={items.length === 0 ? '' : 'display:none'}>
      no screenshots yet.<br />
      paste an image above, or drop files into <code>public/screenshots/</code>.
    </div>
    <div class="grid" id="grid">
      {items.map((item, i) => (
        <figure data-index={i} data-name={item.name}>
          <img src={item.src} alt={item.name} loading="lazy" />
          <button class="del" type="button" aria-label="Delete">&times;</button>
        </figure>
      ))}
    </div>

    <div class="modal" id="modal" aria-hidden="true">
      <button class="close" aria-label="Close">&times;</button>
      <button class="nav prev" aria-label="Previous">&#8249;</button>
      <img id="modal-img" alt="" />
      <button class="nav next" aria-label="Next">&#8250;</button>
      <div class="caption" id="modal-caption"></div>
    </div>

    <script is:inline define:vars={{ items: items }}>
      const state = { items: items.slice() };
      const modal = document.getElementById('modal');
      const modalImg = document.getElementById('modal-img');
      const caption = document.getElementById('modal-caption');
      const grid = document.getElementById('grid');
      const empty = document.getElementById('empty');
      const countEl = document.getElementById('count');
      const pasteZone = document.getElementById('paste-zone');
      let current = 0;

      function updateCount() {
        const n = state.items.length;
        countEl.textContent = `${n} ${n === 1 ? 'image' : 'images'}`;
        if (empty) empty.style.display = n === 0 ? '' : 'none';
      }

      function rebuildIndices() {
        const figures = grid.querySelectorAll('figure');
        figures.forEach((f, i) => f.setAttribute('data-index', String(i)));
      }

      function prependItem(item) {
        state.items.unshift(item);
        const fig = document.createElement('figure');
        fig.dataset.name = item.name;
        const img = document.createElement('img');
        img.src = item.src;
        img.alt = item.name;
        img.loading = 'lazy';
        fig.appendChild(img);
        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'del';
        del.setAttribute('aria-label', 'Delete');
        del.innerHTML = '&times;';
        fig.appendChild(del);
        grid.insertBefore(fig, grid.firstChild);
        rebuildIndices();
        updateCount();
      }

      async function deleteItem(fig) {
        const name = fig.dataset.name;
        if (!name) return;
        if (!confirm(`Delete ${name}?`)) return;
        const res = await fetch(`/api/img/${encodeURIComponent(name)}`, { method: 'DELETE' });
        if (!res.ok) {
          alert('delete failed');
          return;
        }
        const idx = state.items.findIndex((it) => it.name === name);
        if (idx >= 0) state.items.splice(idx, 1);
        fig.remove();
        rebuildIndices();
        updateCount();
      }

      function open(i) {
        if (!state.items.length) return;
        current = (i + state.items.length) % state.items.length;
        const item = state.items[current];
        modalImg.src = item.src;
        modalImg.alt = item.name;
        caption.textContent = item.name;
        modal.classList.add('open');
        modal.setAttribute('aria-hidden', 'false');
      }
      function close() {
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
        modalImg.src = '';
      }
      function next() { open(current + 1); }
      function prev() { open(current - 1); }

      grid.addEventListener('click', (e) => {
        if (e.target.classList && e.target.classList.contains('del')) {
          e.stopPropagation();
          const fig = e.target.closest('figure[data-name]');
          if (fig) deleteItem(fig);
          return;
        }
        const fig = e.target.closest('figure[data-index]');
        if (fig) open(parseInt(fig.dataset.index, 10));
      });

      modal.addEventListener('click', (e) => {
        if (e.target.classList.contains('nav')) {
          if (e.target.classList.contains('next')) next();
          else prev();
          return;
        }
        if (e.target.classList.contains('close') || e.target === modal) close();
      });

      document.addEventListener('keydown', (e) => {
        if (!modal.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowRight') next();
        else if (e.key === 'ArrowLeft') prev();
      });

      // --- paste-to-upload ---
      let resetTimer = null;
      function setStatus(cls, text) {
        pasteZone.className = 'paste-zone' + (cls ? ' ' + cls : '');
        pasteZone.textContent = '';
        if (typeof text === 'string') {
          pasteZone.append(text);
        } else {
          pasteZone.append('paste image here ');
          const k = document.createElement('kbd');
          k.textContent = '⌘V';
          pasteZone.append(k);
        }
        if (resetTimer) clearTimeout(resetTimer);
        if (cls === 'ok' || cls === 'err') {
          resetTimer = setTimeout(() => setStatus('', null), 2000);
        }
      }

      async function uploadBlob(blob, filename) {
        setStatus('busy', 'uploading…');
        const fd = new FormData();
        const file = blob instanceof File ? blob : new File([blob], filename || 'paste.png', { type: blob.type });
        fd.append('image', file);
        const res = await fetch('/api/upload', { method: 'POST', body: fd });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || `upload failed (${res.status})`);
        return data;
      }

      async function handleClipboardItems(items) {
        for (const item of items) {
          if (item.kind === 'file' && item.type.startsWith('image/')) {
            const blob = item.getAsFile();
            if (!blob) continue;
            try {
              await uploadBlob(blob);
              // Optimistic prepend disabled: Vite's public-folder watcher races
              // with it in dev, and the reload below re-runs SSR so the new file
              // shows up via the same path as a cold load.
              // prependItem(result);
              setStatus('ok', 'added ✓');
              setTimeout(() => window.location.reload(), 400);
            } catch (err) {
              setStatus('err', err.message || 'failed');
            }
            return true;
          }
        }
        return false;
      }

      // Paste anywhere on the page (unless typing in modal etc.)
      document.addEventListener('paste', async (e) => {
        if (!e.clipboardData) return;
        const handled = await handleClipboardItems(Array.from(e.clipboardData.items));
        if (handled) e.preventDefault();
      });

      // Keep contenteditable from accumulating text
      pasteZone.addEventListener('input', () => {
        // Reset content if user typed text instead of pasting an image
        if (pasteZone.textContent.length > 64) setStatus('', null);
      });
      pasteZone.addEventListener('focus', () => pasteZone.classList.add('focus'));
      pasteZone.addEventListener('blur', () => pasteZone.classList.remove('focus'));

      updateCount();
    </script>
  </body>
</html>
